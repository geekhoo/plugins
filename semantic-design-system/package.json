{
  "name": "semantic-design-system",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "precoverage": "node -e \"require('fs').mkdirSync('coverage', { recursive: true })\"",
    "coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info tests/*.test.mjs",
    "validate:example": "node scripts/validate-tokens.mjs examples/minimal-tokens",
    "build:example": "node scripts/build-css-vars.mjs examples/minimal-tokens tmp/example-tokens.css ds"
  }
}
