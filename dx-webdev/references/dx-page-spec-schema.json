{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal.local/dx-webdev/dx-page-spec-schema.json",
  "title": "DevExtreme jQuery Page Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "template", "themeCss", "containers", "widgets", "outputFiles"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "enum": ["basic-page", "crud-grid", "dashboard", "form-workflow"]
    },
    "themeCss": {
      "type": "string",
      "minLength": 1
    },
    "devextremeVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "containers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "className": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "widgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["containerId", "type"],
        "properties": {
          "containerId": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "type": { "type": "string", "pattern": "^dx[A-Z][A-Za-z0-9]+$|^DevExpress\\.ui\\.notify$" },
          "dataKey": { "type": "string" },
          "data": { "type": "string" },
          "dataSource": { "type": "string" },
          "options": { "type": "object" },
          "items": { "type": "array" },
          "columns": { "type": "array" }
        }
      }
    },
    "sampleData": {
      "type": "object",
      "additionalProperties": {
        "type": "array"
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "outputFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["index.html", "styles.css", "app.js"]
      },
      "minItems": 3,
      "uniqueItems": true
    }
  }
}
